<Window x:Class="SnapForge.ImageViewerPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="Image Viewer"
        Width="860"
        Height="620"
        MinWidth="520"
        MinHeight="360"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#EAF0FF"
        Topmost="True">
    <Border x:Name="RootBorder"
            Background="{DynamicResource Sf.SteamCardBackground}"
            BorderBrush="{DynamicResource Sf.SteamCardBorder}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="10"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border x:Name="HeaderBar"
                    Background="#182033"
                    BorderBrush="#2A3C58"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="8"
                    Margin="0,0,0,8"
                    MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Open Preview" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock x:Name="FileNameText" Foreground="#9FB0C8" FontSize="12" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="-" Width="30" Height="26" Margin="0,0,6,0" Style="{DynamicResource Sf.ImGuiButton}" Click="ZoomOutButton_Click" />
                        <TextBlock x:Name="ZoomText" Width="56" VerticalAlignment="Center" TextAlignment="Center" />
                        <Button Content="+" Width="30" Height="26" Margin="6,0,6,0" Style="{DynamicResource Sf.ImGuiButton}" Click="ZoomInButton_Click" />
                        <Button Content="Edit" Width="52" Height="26" Margin="0,0,6,0" Style="{DynamicResource Sf.ImGuiButton}" Click="EditButton_Click" />
                        <Button Content="Delete" Width="62" Height="26" Margin="0,0,6,0" Background="#C93232" Foreground="White" Click="DeleteButton_Click" />
                        <Button Content="✕" Width="32" Height="26" Style="{DynamicResource Sf.ImGuiButton}" Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="◀"
                        Width="38"
                        Height="38"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Style="{DynamicResource Sf.ImGuiButton}"
                        Click="PrevButton_Click" />

                <Border Grid.Column="1"
                        Background="#0B1018"
                        BorderBrush="#2A3C58"
                        BorderThickness="1"
                        CornerRadius="10"
                        ClipToBounds="True">
                    <Grid x:Name="ViewportHost"
                          Background="Transparent"
                          SizeChanged="ViewportHost_SizeChanged"
                          MouseLeftButtonDown="ViewportHost_MouseLeftButtonDown"
                          MouseLeftButtonUp="ViewportHost_MouseLeftButtonUp"
                          MouseMove="ViewportHost_MouseMove"
                          PreviewMouseWheel="ViewportHost_PreviewMouseWheel">
                        <Image x:Name="PreviewImage"
                               Stretch="Uniform"
                               RenderTransformOrigin="0,0">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1" />
                                    <TranslateTransform x:Name="ImageTranslateTransform" X="0" Y="0" />
                                </TransformGroup>
                            </Image.RenderTransform>
                        </Image>
                    </Grid>
                </Border>

                <Button Grid.Column="2"
                        Content="▶"
                        Width="38"
                        Height="38"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Style="{DynamicResource Sf.ImGuiButton}"
                        Click="NextButton_Click" />
            </Grid>
            <primitives:Thumb Grid.RowSpan="2"
                              Width="14"
                              Height="14"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="0,0,2,2"
                              Cursor="SizeNWSE"
                              DragDelta="ResizeThumb_DragDelta">
                <primitives:Thumb.Template>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Border Background="#4D6FAE" CornerRadius="2" />
                    </ControlTemplate>
                </primitives:Thumb.Template>
            </primitives:Thumb>
        </Grid>
    </Border>
</Window>
