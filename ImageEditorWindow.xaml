<Window x:Class="SnapForge.ImageEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="Image Editor"
        Width="1100"
        Height="760"
        MinWidth="760"
        MinHeight="460"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#0E131D"
        Foreground="#EAF0FF"
        Topmost="True">
    <Border x:Name="RootBorder"
            Background="{DynamicResource Sf.SteamCardBackground}"
            BorderBrush="{DynamicResource Sf.SteamCardBorder}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="10"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#182033"
                    BorderBrush="#2A3C58"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="8"
                    Margin="0,0,0,8"
                    MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Image Editor" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="Brush, text, zoom and save copy" FontSize="12" Foreground="#9FB0C8" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="-" Width="30" Height="26" Margin="0,0,6,0" Style="{DynamicResource Sf.ImGuiButton}" Click="ZoomOutButton_Click" />
                        <TextBlock x:Name="ZoomText" Width="56" VerticalAlignment="Center" TextAlignment="Center" />
                        <Button Content="+" Width="30" Height="26" Margin="6,0,6,0" Style="{DynamicResource Sf.ImGuiButton}" Click="ZoomInButton_Click" />
                        <Button Content="✕" Width="32" Height="26" Style="{DynamicResource Sf.ImGuiButton}" Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                <Button Content="Brush Mode" Width="98" Margin="0,0,8,6" Style="{DynamicResource Sf.ImGuiButton}" Click="BrushModeButton_Click" />
                <Button Content="Text Mode" Width="92" Margin="0,0,8,6" Style="{DynamicResource Sf.ImGuiButton}" Click="TextModeButton_Click" />
                <Button Content="Delete Text" Width="92" Margin="0,0,8,6" Style="{DynamicResource Sf.ImGuiButton}" Click="DeleteTextButton_Click" />
                <Button Content="Undo" Width="72" Margin="0,0,8,6" Style="{DynamicResource Sf.ImGuiButton}" Click="UndoButton_Click" />
                <Button Content="Save" Width="72" Margin="0,0,8,6" Style="{DynamicResource Sf.ImGuiButton}" Click="SaveButton_Click" />
                <Button Content="Save As" Width="84" Margin="0,0,8,6" Style="{DynamicResource Sf.ImGuiButton}" Click="SaveAsButton_Click" />
                <TextBlock Text="Brush size" VerticalAlignment="Center" Margin="0,0,8,6" />
                <Slider x:Name="BrushSizeSlider" Width="120" Minimum="2" Maximum="22" Value="5" Margin="0,0,12,6" ValueChanged="BrushSizeSlider_ValueChanged" />
                <TextBlock Text="Text size" VerticalAlignment="Center" Margin="0,0,8,6" />
                <Slider x:Name="TextSizeSlider" Width="120" Minimum="12" Maximum="48" Value="24" Margin="0,0,12,6" ValueChanged="TextSizeSlider_ValueChanged" />
                <TextBlock Text="Text width" VerticalAlignment="Center" Margin="0,0,8,6" />
                <Slider x:Name="TextWidthSlider" Width="120" Minimum="120" Maximum="420" Value="220" Margin="0,0,12,6" ValueChanged="TextWidthSlider_ValueChanged" />
                <TextBlock Text="Color" VerticalAlignment="Center" Margin="0,0,8,6" />
                <ComboBox x:Name="ColorComboBox" Width="110" Margin="0,0,0,6" SelectionChanged="ColorComboBox_SelectionChanged">
                    <ComboBoxItem Content="Red" />
                    <ComboBoxItem Content="Green" />
                    <ComboBoxItem Content="Blue" />
                    <ComboBoxItem Content="Yellow" />
                    <ComboBoxItem Content="White" />
                </ComboBox>
            </WrapPanel>

            <Border Grid.Row="2"
                    Background="#0B1018"
                    BorderBrush="#2A3C58"
                    BorderThickness="1"
                    CornerRadius="10"
                    ClipToBounds="True">
                <ScrollViewer x:Name="EditorScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="EditorScrollViewer_PreviewMouseWheel">
                    <Grid x:Name="EditorSurface" Background="#0A0F16" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="EditorScaleTransform" ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <Image x:Name="BaseImage" Stretch="Uniform" />
                        <InkCanvas x:Name="InkLayer" Background="Transparent" MouseLeftButtonDown="InkLayer_MouseLeftButtonDown" />
                        <Canvas x:Name="TextLayer" Background="Transparent" IsHitTestVisible="True" />
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Window>
