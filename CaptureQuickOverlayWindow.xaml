<Window x:Class="SnapForge.CaptureQuickOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="SnapForge Quick Overlay"
        Width="350"
        Height="228"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">
    <Border x:Name="RootBorder"
            CornerRadius="16"
            BorderBrush="{DynamicResource Sf.SteamCardBorder}"
            BorderThickness="1"
            Background="{DynamicResource Sf.SteamCardBackground}"
            Padding="10"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown"
            MouseMove="RootBorder_MouseMove"
            MouseLeftButtonUp="RootBorder_MouseLeftButtonUp">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="DragHeader"
                    Grid.Row="0"
                    Background="#1A2538"
                    CornerRadius="12"
                    Padding="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="SnapForge Overlay"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Foreground="#EAF0FF" />
                        <TextBlock x:Name="FileNameText"
                                   Margin="0,4,0,0"
                                   Foreground="#9FB0C8"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="SettingsToggleButton"
                                Content="⚙"
                                Width="34"
                                Height="30"
                                Margin="0,0,6,0"
                                Style="{DynamicResource Sf.ImGuiButton}"
                                Click="SettingsToggleButton_Click" />
                        <Button Content="✕"
                                Width="34"
                                Height="30"
                                Style="{DynamicResource Sf.ImGuiButton}"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,8,0,8"
                    Background="#0F1622"
                    CornerRadius="12"
                    BorderBrush="#2A3C58"
                    BorderThickness="1"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border CornerRadius="10" ClipToBounds="True" Background="#0B1018">
                        <Grid>
                            <Image x:Name="PreviewImage" Stretch="UniformToFill" />
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,6,6,0">
                                <Button Content="Open"
                                        Width="52"
                                        Height="24"
                                        Margin="0,0,6,0"
                                        FontSize="11"
                                        Style="{DynamicResource Sf.ImGuiButton}"
                                        Click="OpenButton_Click" />
                                <Button Content="Edit"
                                        Width="52"
                                        Height="24"
                                        FontSize="11"
                                        Style="{DynamicResource Sf.ImGuiButton}"
                                        Click="EditButton_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="0,8,0,0">
                        <TextBlock Text="Actions"
                                   FontWeight="SemiBold"
                                   Foreground="#EAF0FF"
                                   Margin="0,0,0,6" />
                        <UniformGrid Rows="1" Columns="2" Margin="0,0,0,0">
                            <Button Content="Send" Margin="0,0,6,0" Style="{DynamicResource Sf.ImGuiButton}" Click="SendButton_Click" />
                            <Button Content="Copy" Margin="0,0,0,0" Style="{DynamicResource Sf.ImGuiButton}" Click="CopyButton_Click" />
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="SettingsPanel"
                    Grid.Row="2"
                    Background="#141A27"
                    CornerRadius="12"
                    BorderBrush="#2A3C58"
                    BorderThickness="1"
                    Padding="10"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Overlay settings"
                               FontWeight="SemiBold"
                               Foreground="#EAF0FF"
                               Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Opacity" VerticalAlignment="Center" Width="90" Foreground="#9FB0C8" />
                        <Slider x:Name="OpacitySlider" Width="240" Minimum="0.55" Maximum="1" ValueChanged="OpacitySlider_ValueChanged" />
                    </StackPanel>
                    <CheckBox x:Name="AutoDismissCheckBox"
                              Foreground="#EAF0FF"
                              Content="Auto dismiss"
                              Checked="AutoDismiss_Changed"
                              Unchecked="AutoDismiss_Changed" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Dismiss (ms)" VerticalAlignment="Center" Width="90" Foreground="#9FB0C8" />
                        <Slider x:Name="DismissMsSlider" Width="240" Minimum="2000" Maximum="20000" TickFrequency="500" IsSnapToTickEnabled="True" ValueChanged="DismissMsSlider_ValueChanged" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <primitives:Thumb Width="14"
                              Height="14"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="0,0,2,2"
                              Cursor="SizeNWSE"
                              DragDelta="ResizeThumb_DragDelta">
                <primitives:Thumb.Template>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Border Background="#4D6FAE" CornerRadius="2" />
                    </ControlTemplate>
                </primitives:Thumb.Template>
            </primitives:Thumb>
        </Grid>
    </Border>
</Window>
