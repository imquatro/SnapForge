<Window x:Class="SnapForge.OverlayToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OverlayToast"
        Width="336"
        Height="232"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Topmost="True">
    <Border x:Name="RootCard"
            Background="{DynamicResource Sf.SteamCardBackground}"
            CornerRadius="14"
            BorderBrush="{DynamicResource Sf.SteamCardBorder}"
            BorderThickness="1"
            Padding="10">
        <StackPanel>
            <TextBlock Text="Capture created"
                       Foreground="#EAF0FF"
                       FontWeight="Bold"
                       FontSize="14" />
            <TextBlock x:Name="HintText"
                       Text="Press Shift+F12 for overlay"
                       Foreground="#AFC6F2"
                       FontSize="12"
                       Margin="0,2,0,8" />
            <Border Background="#0B1018"
                    BorderBrush="#2A3C58"
                    BorderThickness="1"
                    CornerRadius="10"
                    ClipToBounds="True">
                <Image x:Name="PreviewImage" Height="165" Stretch="UniformToFill" />
            </Border>
        </StackPanel>
    </Border>
</Window>
