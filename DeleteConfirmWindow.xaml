<Window x:Class="SnapForge.DeleteConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Delete"
        Width="380"
        Height="210"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True">
    <Border Background="{DynamicResource Sf.SteamCardBackground}"
            BorderBrush="{DynamicResource Sf.SteamCardBorder}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="#182033" BorderBrush="#2A3C58" BorderThickness="1" CornerRadius="10" Padding="8">
                <TextBlock Text="Delete image"
                           Foreground="#EAF0FF"
                           FontWeight="SemiBold"
                           FontSize="14" />
            </Border>

            <StackPanel Grid.Row="1" Margin="0,10,0,10">
                <TextBlock x:Name="MessageText"
                           TextWrapping="Wrap"
                           Foreground="#D6DEEF"
                           Margin="0,0,0,10" />
                <CheckBox x:Name="NotAskAgainCheckBox"
                          Content="Do not ask again"
                          Foreground="#EAF0FF" />
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Width="90"
                        Height="30"
                        Margin="0,0,8,0"
                        Style="{DynamicResource Sf.ImGuiButton}"
                        Click="CancelButton_Click" />
                <Button Content="Delete"
                        Width="90"
                        Height="30"
                        Background="#C93232"
                        Foreground="White"
                        Click="DeleteButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
