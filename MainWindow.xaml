<Window x:Class="SnapForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SnapForge Desktop Panel"
        Width="860"
        Height="900"
        MinWidth="760"
        MinHeight="600"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        Foreground="#EAF0FF"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Border Background="{DynamicResource Sf.SteamCardBackground}"
            BorderBrush="{DynamicResource Sf.SteamCardBorder}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#182033"
                    BorderBrush="#2A3C58"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="8"
                    Margin="0,0,0,8"
                    MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="SnapForge"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="  •  Desktop Panel"
                                   Margin="8,0,0,0"
                                   Foreground="#AFC6F2"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Capture"
                                Height="28"
                                Margin="0,0,8,0"
                                Style="{DynamicResource Sf.ImGuiButton}"
                                Click="CaptureButton_Click" />
                        <Button Content="✕"
                                Width="32"
                                Height="28"
                                Style="{DynamicResource Sf.ImGuiButton}"
                                Click="CloseToTrayButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl x:Name="MainTabControl"
                        Grid.Row="1"
                        Style="{DynamicResource Sf.ImGuiTabControl}"
                        Background="#101826"
                        BorderBrush="#2A3C58">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource Sf.ImGuiTabItem}" />
                </TabControl.Resources>
                <TabItem Header="Recent">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Recent Screenshots"
                                           FontSize="14.5"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="CaptureResultText"
                                           Margin="10,0,0,0"
                                           Foreground="#88D8A3"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="Zoom"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <Slider x:Name="ThumbSizeSlider"
                                        Style="{DynamicResource Sf.ImGuiSlider}"
                                        Width="130"
                                        Minimum="90"
                                        Maximum="260"
                                        ValueChanged="ThumbSizeSlider_ValueChanged" />
                                <Button Content="Folder"
                                        Height="24"
                                        Margin="8,0,0,0"
                                        Style="{DynamicResource Sf.ImGuiButton}"
                                        Click="OpenCaptureFolderButton_Click" />
                            </StackPanel>
                        </Grid>
                        <ScrollViewer Grid.Row="1"
                                      Style="{DynamicResource Sf.ImGuiScrollViewer}"
                                      VerticalScrollBarVisibility="Hidden"
                                      PreviewMouseWheel="GalleryScrollViewer_PreviewMouseWheel">
                            <ItemsControl x:Name="GalleryItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="{Binding ThumbSize}"
                                                Height="{Binding ThumbSize}"
                                                Margin="0,0,8,8"
                                                Background="#1A2536"
                                                CornerRadius="8"
                                                BorderBrush="#2A3C58"
                                                BorderThickness="1"
                                                MouseLeftButtonDown="RecentTile_MouseLeftButtonDown">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="#2A3C58" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#FFD254" />
                                                            <Setter Property="BorderThickness" Value="2" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" ClipToBounds="True" />
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Margin="0,5,5,0">
                                                    <Button Content="Open"
                                                            Width="46"
                                                            Height="20"
                                                            Margin="0,0,3,0"
                                                            FontSize="9.5"
                                                            Tag="{Binding FilePath}"
                                                            Style="{DynamicResource Sf.ImGuiButton}"
                                                            Click="OpenImageButton_Click" />
                                                    <Button Content="Edit"
                                                            Width="46"
                                                            Height="20"
                                                            Margin="0,0,3,0"
                                                            FontSize="9.5"
                                                            Tag="{Binding FilePath}"
                                                            Style="{DynamicResource Sf.ImGuiButton}"
                                                            Click="EditImageButton_Click" />
                                                    <Button Content="Send"
                                                            Width="46"
                                                            Height="20"
                                                            Margin="0,0,3,0"
                                                            FontSize="9.5"
                                                            Tag="{Binding FilePath}"
                                                            Style="{DynamicResource Sf.ImGuiButton}"
                                                            Click="SendImageButton_Click" />
                                                    <Button Content="Delete"
                                                            Width="50"
                                                            Height="20"
                                                            FontSize="9.5"
                                                            Background="#C93232"
                                                            Foreground="White"
                                                            Tag="{Binding FilePath}"
                                                            Click="DeleteImageButton_Click" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <TabItem Header="Viewer">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="◀" Width="30" Height="24" Margin="0,0,6,0" Style="{DynamicResource Sf.ImGuiButton}" Click="ViewerPrevButton_Click" />
                            <Button Content="▶" Width="30" Height="24" Margin="0,0,6,0" Style="{DynamicResource Sf.ImGuiButton}" Click="ViewerNextButton_Click" />
                            <Button Content="-" Width="24" Height="24" Margin="0,0,5,0" Style="{DynamicResource Sf.ImGuiButton}" Click="ViewerZoomOutButton_Click" />
                            <TextBlock x:Name="ViewerZoomText" Width="56" VerticalAlignment="Center" TextAlignment="Center" />
                            <Button Content="+" Width="24" Height="24" Margin="5,0,6,0" Style="{DynamicResource Sf.ImGuiButton}" Click="ViewerZoomInButton_Click" />
                            <Button Content="Edit" Width="50" Height="24" Margin="0,0,6,0" Style="{DynamicResource Sf.ImGuiButton}" Click="ViewerEditButton_Click" />
                            <Button Content="Delete" Width="58" Height="24" Background="#C93232" Foreground="White" Click="ViewerDeleteButton_Click" />
                        </StackPanel>
                        <Border Grid.Row="1"
                                Background="#0B1018"
                                BorderBrush="#2A3C58"
                                BorderThickness="1"
                                CornerRadius="10"
                                ClipToBounds="True">
                            <Grid x:Name="ViewerViewportHost"
                                  Background="Transparent"
                                  SizeChanged="ViewerViewportHost_SizeChanged"
                                  MouseLeftButtonDown="ViewerViewportHost_MouseLeftButtonDown"
                                  MouseLeftButtonUp="ViewerViewportHost_MouseLeftButtonUp"
                                  MouseMove="ViewerViewportHost_MouseMove"
                                  PreviewMouseWheel="ViewerViewportHost_PreviewMouseWheel">
                                <Image x:Name="ViewerImage" Stretch="Uniform" RenderTransformOrigin="0,0">
                                    <Image.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="ViewerScaleTransform" ScaleX="1" ScaleY="1" />
                                            <TranslateTransform x:Name="ViewerTranslateTransform" X="0" Y="0" />
                                        </TransformGroup>
                                    </Image.RenderTransform>
                                </Image>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Editor">
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="165" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#101826"
                                BorderBrush="#2A3C58"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="8"
                                Margin="0,0,8,0">
                            <StackPanel>
                                <Button Content="Undo" Height="24" Margin="0,0,0,5" Style="{DynamicResource Sf.ImGuiButton}" Click="EditorUndoButton_Click" />
                                <Button x:Name="EditorCutModeButton" Content="Cut" Height="24" Margin="0,0,0,5" Style="{DynamicResource Sf.ImGuiButton}" Click="EditorCutModeButton_Click" />
                                <Button Content="Save" Height="24" Margin="0,0,0,8" Style="{DynamicResource Sf.ImGuiButton}" Click="EditorSaveButton_Click" />
                                <TextBlock Text="Brush size" Margin="0,0,0,4" />
                                <Slider x:Name="EditorBrushSizeSlider" Minimum="2" Maximum="28" Value="6" Style="{DynamicResource Sf.ImGuiSlider}" />
                                <TextBlock Text="Color picker" Margin="0,10,0,4" />
                                <Grid x:Name="EditorColorPlane"
                                      Height="95"
                                      Margin="0,0,0,6"
                                      MouseLeftButtonDown="EditorColorPlane_MouseLeftButtonDown"
                                      MouseLeftButtonUp="EditorColorPlane_MouseLeftButtonUp"
                                      MouseMove="EditorColorPlane_MouseMove">
                                    <Rectangle x:Name="EditorColorPlaneHueBase">
                                        <Rectangle.Fill>
                                            <SolidColorBrush Color="#FF0000" />
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <Rectangle>
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="White" Offset="0" />
                                                <GradientStop Color="#00FFFFFF" Offset="1" />
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <Rectangle>
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00000000" Offset="0" />
                                                <GradientStop Color="#FF000000" Offset="1" />
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <Ellipse x:Name="EditorColorPlaneMarker"
                                             Width="10"
                                             Height="10"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Top"
                                             Stroke="White"
                                             StrokeThickness="1.5"
                                             Fill="#33000000"
                                             IsHitTestVisible="False" />
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Rectangle RadiusX="3" RadiusY="3">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                <GradientStop Color="#FFFF0000" Offset="0" />
                                                <GradientStop Color="#FFFFFF00" Offset="0.17" />
                                                <GradientStop Color="#FF00FF00" Offset="0.33" />
                                                <GradientStop Color="#FF00FFFF" Offset="0.5" />
                                                <GradientStop Color="#FF0000FF" Offset="0.67" />
                                                <GradientStop Color="#FFFF00FF" Offset="0.83" />
                                                <GradientStop Color="#FFFF0000" Offset="1" />
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <Slider x:Name="EditorHueSlider"
                                            Style="{DynamicResource Sf.ImGuiSlider}"
                                            Background="#00FFFFFF"
                                            Minimum="0"
                                            Maximum="360"
                                            Value="15"
                                            ValueChanged="EditorHueSlider_ValueChanged" />
                                </Grid>
                                <Border x:Name="EditorColorPreview" Height="18" Margin="0,8,0,0" CornerRadius="4" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Background="#0B1018"
                                BorderBrush="#2A3C58"
                                BorderThickness="1"
                                CornerRadius="10"
                                ClipToBounds="True">
                            <Grid x:Name="EditorViewportHost"
                                  Background="Transparent"
                                  SizeChanged="EditorViewportHost_SizeChanged"
                                  MouseLeftButtonDown="EditorViewportHost_MouseLeftButtonDown"
                                  MouseLeftButtonUp="EditorViewportHost_MouseLeftButtonUp"
                                  MouseRightButtonDown="EditorViewportHost_MouseRightButtonDown"
                                  MouseRightButtonUp="EditorViewportHost_MouseRightButtonUp"
                                  MouseMove="EditorViewportHost_MouseMove"
                                  PreviewMouseWheel="EditorViewportHost_PreviewMouseWheel">
                                <Grid x:Name="EditorImageLayer" RenderTransformOrigin="0,0">
                                    <Grid.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="EditorScaleTransform" ScaleX="1" ScaleY="1" />
                                            <TranslateTransform x:Name="EditorTranslateTransform" X="0" Y="0" />
                                        </TransformGroup>
                                    </Grid.RenderTransform>
                                    <Image x:Name="EditorBaseImage" Stretch="Uniform" />
                                    <Canvas x:Name="EditorDrawLayer" Background="Transparent" />
                                </Grid>
                                <Canvas x:Name="EditorCropOverlay"
                                        Background="Transparent"
                                        Visibility="Collapsed"
                                        PreviewMouseLeftButtonDown="EditorCropOverlay_PreviewMouseLeftButtonDown"
                                        PreviewMouseMove="EditorCropOverlay_PreviewMouseMove"
                                        PreviewMouseLeftButtonUp="EditorCropOverlay_PreviewMouseLeftButtonUp">
                                    <Border x:Name="EditorCropRect"
                                            Width="220"
                                            Height="160"
                                            BorderBrush="#FFD254"
                                            BorderThickness="2"
                                            Background="#33000000"
                                            MouseLeftButtonDown="EditorCropRect_MouseLeftButtonDown"
                                            MouseMove="EditorCropRect_MouseMove"
                                            MouseLeftButtonUp="EditorCropRect_MouseLeftButtonUp"
                                            MouseEnter="EditorCropRect_MouseEnter"
                                            MouseLeave="EditorCropRect_MouseLeave">
                                        <Grid>
                                            <primitives:Thumb Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="SizeNWSE" DragDelta="EditorCropTopLeftThumb_DragDelta" />
                                            <primitives:Thumb Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="SizeNESW" DragDelta="EditorCropTopRightThumb_DragDelta" />
                                            <primitives:Thumb Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="SizeNESW" DragDelta="EditorCropBottomLeftThumb_DragDelta" />
                                            <primitives:Thumb Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" DragDelta="EditorCropBottomRightThumb_DragDelta" />
                                        </Grid>
                                    </Border>
                                    <Button x:Name="EditorApplyCutButton"
                                            Content="Cut"
                                            Width="60"
                                            Height="26"
                                            Visibility="Collapsed"
                                            Style="{DynamicResource Sf.ImGuiButton}"
                                            Click="EditorApplyCutButton_Click" />
                                </Canvas>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Capture">
                    <StackPanel Margin="10">
                        <Button Content="Take Screenshot"
                                Width="170"
                                Height="24"
                                Margin="0,0,0,6"
                                Style="{DynamicResource Sf.ImGuiButton}"
                                Click="CaptureButton_Click" />
                        <Button Content="Show quick capture content"
                                Width="220"
                                Height="24"
                                Margin="0,0,0,6"
                                Style="{DynamicResource Sf.ImGuiButton}"
                                Click="ShowQuickCaptureTabButton_Click" />
                        <TextBlock Text="Notification duration (ms)" Margin="0,8,0,4" />
                        <Slider x:Name="NotificationDurationSlider" Minimum="800" Maximum="4000" TickFrequency="200" IsSnapToTickEnabled="True" ValueChanged="NotificationDurationSlider_ValueChanged" Style="{DynamicResource Sf.ImGuiSlider}" />
                        <TextBlock x:Name="NotificationDurationText" Foreground="#9DB2D4" Margin="0,4,0,0" />
                    </StackPanel>
                </TabItem>

                <TabItem Header="Settings">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden" Style="{DynamicResource Sf.ImGuiScrollViewer}">
                        <StackPanel Margin="10">
                            <TextBlock Text="Save folder" Margin="0,0,0,4" />
                            <TextBox x:Name="SaveDirectoryTextBox" IsReadOnly="True" Margin="0,0,0,8" Style="{DynamicResource Sf.ImGuiTextBox}" />
                            <Button Content="Change Folder" Width="140" Height="30" Margin="0,0,0,10" Style="{DynamicResource Sf.ImGuiButton}" Click="BrowseButton_Click" />
                            <CheckBox x:Name="StartWithWindowsCheckBox"
                                      Content="Start with Windows"
                                      Margin="0,0,0,12"
                                      Style="{DynamicResource Sf.ImGuiCheckBox}"
                                      Checked="StartWithWindowsCheckBox_Changed"
                                      Unchecked="StartWithWindowsCheckBox_Changed" />
                            <TextBlock Text="Capture hotkey" />
                            <Grid Margin="0,6,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Shift +"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBox x:Name="CaptureHotkeyTextBox"
                                         Grid.Column="1"
                                         Width="64"
                                         Height="32"
                                         HorizontalAlignment="Left"
                                         VerticalContentAlignment="Center"
                                         TextAlignment="Center"
                                         IsReadOnly="False"
                                         Style="{DynamicResource Sf.ImGuiTextBox}"
                                         GotKeyboardFocus="HotkeyTextBox_GotKeyboardFocus"
                                         PreviewKeyDown="HotkeyTextBox_PreviewKeyDown" />
                            </Grid>
                            <TextBlock Text="Overlay hotkey" />
                            <Grid Margin="0,6,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Shift +"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBox x:Name="OverlayHotkeyTextBox"
                                         Grid.Column="1"
                                         Width="64"
                                         Height="32"
                                         HorizontalAlignment="Left"
                                         VerticalContentAlignment="Center"
                                         TextAlignment="Center"
                                         IsReadOnly="False"
                                         Style="{DynamicResource Sf.ImGuiTextBox}"
                                         GotKeyboardFocus="HotkeyTextBox_GotKeyboardFocus"
                                         PreviewKeyDown="HotkeyTextBox_PreviewKeyDown" />
                            </Grid>
                            <Button Content="Save Hotkeys" Width="130" Height="30" Style="{DynamicResource Sf.ImGuiButton}" Click="ApplyHotkeyButton_Click" />
                            <Border Margin="0,12,0,0"
                                    Padding="8"
                                    CornerRadius="8"
                                    Background="#0F1725"
                                    BorderBrush="#2A3C58"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="App updates"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6" />
                                    <TextBlock x:Name="CurrentVersionText"
                                               Text="Current version: -"
                                               Foreground="#9EC0F7" />
                                    <TextBlock x:Name="LatestVersionText"
                                               Text="Latest version: -"
                                               Foreground="#9EC0F7"
                                               Margin="0,2,0,0" />
                                    <Button Content="Check for updates"
                                            Width="150"
                                            Height="28"
                                            Margin="0,8,0,0"
                                            Style="{DynamicResource Sf.ImGuiButton}"
                                            Click="CheckUpdatesButton_Click" />
                                    <Button x:Name="OpenUpdateButton"
                                            Content="Open update download"
                                            Width="170"
                                            Height="28"
                                            Margin="0,6,0,0"
                                            Visibility="Collapsed"
                                            Style="{DynamicResource Sf.ImGuiButton}"
                                            Click="OpenUpdateButton_Click" />
                                    <ProgressBar x:Name="UpdateProgressBar"
                                                 Height="10"
                                                 Margin="0,8,0,0"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Visibility="Collapsed"
                                                 Value="0" />
                                    <TextBlock x:Name="UpdateProgressText"
                                               Margin="0,4,0,0"
                                               Foreground="#9EC0F7"
                                               Visibility="Collapsed"
                                               Text="Progress: 0%" />
                                    <TextBlock x:Name="UpdateStatusText"
                                               Margin="0,8,0,0"
                                               Foreground="#9EC0F7"
                                               TextWrapping="Wrap"
                                               Text="Set your GitHub repo in MainWindow.xaml.cs to enable update checks." />
                                </StackPanel>
                            </Border>
                            <Border Margin="0,10,0,0"
                                    Padding="8"
                                    CornerRadius="8"
                                    Background="#111A29"
                                    BorderBrush="#2A3C58"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Keyboard shortcuts"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="Ctrl+S - Save image (Editor tab)"
                                               Foreground="#9EC0F7" />
                                    <TextBlock Text="Ctrl+Z - Undo draw (Editor tab)"
                                               Foreground="#9EC0F7" />
                                    <TextBlock Text="Ctrl+V - Open Viewer tab"
                                               Foreground="#9EC0F7" />
                                    <TextBlock Text="Left / Right Arrow - Previous / Next image (Viewer tab)"
                                               TextWrapping="Wrap"
                                               Foreground="#9EC0F7" />
                                </StackPanel>
                            </Border>
                            <TextBlock x:Name="HotkeyStatusText"
                                       Margin="0,10,0,0"
                                       Foreground="#9EC0F7"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Support">
                    <Grid Margin="10">
                        <Border Background="#111A29"
                                BorderBrush="#2A3C58"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Support"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="If you like this app, you can support the project."
                                           Foreground="#9EC0F7"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10" />
                                <Button Content="Buy me a coffee"
                                        Width="150"
                                        Height="30"
                                        Margin="0,0,0,10"
                                        Style="{DynamicResource Sf.ImGuiButton}"
                                        Click="BuyMeCoffeeButton_Click" />
                                <TextBlock Foreground="#9EC0F7">
                                    <Hyperlink Click="FacebookSupportLink_Click">Open Facebook support page</Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
