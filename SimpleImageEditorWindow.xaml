<Window x:Class="SnapForge.SimpleImageEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="Image Editor"
        Width="960"
        Height="620"
        MinWidth="700"
        MinHeight="420"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#EAF0FF"
        Topmost="True"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Border x:Name="RootBorder"
            Background="{DynamicResource Sf.SteamCardBackground}"
            BorderBrush="{DynamicResource Sf.SteamCardBorder}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="10"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#182033"
                    BorderBrush="#2A3C58"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="8"
                    Margin="0,0,0,8"
                    MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Edit Preview" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Save" Width="60" Height="26" Margin="0,0,6,0" Style="{DynamicResource Sf.ImGuiButton}" Click="SaveButton_Click" />
                        <TextBlock x:Name="ZoomText" Width="55" VerticalAlignment="Center" TextAlignment="Center" />
                        <Button Content="✕" Width="32" Height="26" Margin="6,0,0,0" Style="{DynamicResource Sf.ImGuiButton}" Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#101826"
                        BorderBrush="#2A3C58"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="8"
                        Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Brushes" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Button Content="Undo" Height="28" Margin="0,0,0,6" Style="{DynamicResource Sf.ImGuiButton}" Click="UndoButton_Click" />
                        <Button x:Name="CutModeButton"
                                Content="Cut"
                                Height="28"
                                Margin="0,0,0,6"
                                Style="{DynamicResource Sf.ImGuiButton}"
                                Click="CutModeButton_Click" />
                        <TextBlock Text="Color picker" Margin="0,0,0,4" />
                        <Grid x:Name="ColorPlane"
                              Height="95"
                              Margin="0,0,0,6"
                              MouseLeftButtonDown="ColorPlane_MouseLeftButtonDown"
                              MouseLeftButtonUp="ColorPlane_MouseLeftButtonUp"
                              MouseMove="ColorPlane_MouseMove">
                            <Rectangle x:Name="ColorPlaneHueBase">
                                <Rectangle.Fill>
                                    <SolidColorBrush Color="#FF0000" />
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle>
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="White" Offset="0" />
                                        <GradientStop Color="#00FFFFFF" Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle>
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#00000000" Offset="0" />
                                        <GradientStop Color="#FF000000" Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Ellipse x:Name="ColorPlaneMarker"
                                     Width="10"
                                     Height="10"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Top"
                                     Stroke="White"
                                     StrokeThickness="1.5"
                                     Fill="#33000000"
                                     IsHitTestVisible="False" />
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Rectangle RadiusX="3" RadiusY="3">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Color="#FFFF0000" Offset="0" />
                                        <GradientStop Color="#FFFFFF00" Offset="0.17" />
                                        <GradientStop Color="#FF00FF00" Offset="0.33" />
                                        <GradientStop Color="#FF00FFFF" Offset="0.5" />
                                        <GradientStop Color="#FF0000FF" Offset="0.67" />
                                        <GradientStop Color="#FFFF00FF" Offset="0.83" />
                                        <GradientStop Color="#FFFF0000" Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Slider x:Name="HueSlider"
                                    Background="#00FFFFFF"
                                    Minimum="0"
                                    Maximum="360"
                                    Value="15"
                                    ValueChanged="HueSlider_ValueChanged" />
                        </Grid>
                        <Border x:Name="ColorPreview" Height="16" Margin="0,0,0,8" CornerRadius="4" Background="OrangeRed" />
                        <TextBlock Text="Brush size" Margin="0,0,0,4" />
                        <Slider x:Name="BrushSizeSlider" Minimum="2" Maximum="28" Value="6" ValueChanged="BrushSizeSlider_ValueChanged" />
                        <TextBlock Text="Mode" Margin="0,10,0,4" />
                        <TextBlock x:Name="ModeText" Text="Draw (always on)" Foreground="#9FB0C8" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="#0B1018"
                        BorderBrush="#2A3C58"
                        BorderThickness="1"
                        CornerRadius="10"
                        ClipToBounds="True">
                    <Grid x:Name="ViewportHost"
                          Background="Transparent"
                          SizeChanged="ViewportHost_SizeChanged"
                          MouseLeftButtonDown="ViewportHost_MouseLeftButtonDown"
                          MouseLeftButtonUp="ViewportHost_MouseLeftButtonUp"
                          MouseRightButtonDown="ViewportHost_MouseRightButtonDown"
                          MouseRightButtonUp="ViewportHost_MouseRightButtonUp"
                          MouseMove="ViewportHost_MouseMove"
                          PreviewMouseWheel="ViewportHost_PreviewMouseWheel">
                        <Grid x:Name="ImageLayer" RenderTransformOrigin="0,0">
                            <Grid.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1" />
                                    <TranslateTransform x:Name="ImageTranslateTransform" X="0" Y="0" />
                                </TransformGroup>
                            </Grid.RenderTransform>
                            <Image x:Name="BaseImage" Stretch="Uniform" />
                            <Canvas x:Name="DrawLayer" Background="Transparent" />
                        </Grid>
                        <Canvas x:Name="CropOverlay"
                                Background="Transparent"
                                Visibility="Collapsed"
                                SizeChanged="CropOverlay_SizeChanged">
                            <Border x:Name="CropRect"
                                    Width="220"
                                    Height="160"
                                    BorderBrush="#FFD254"
                                    BorderThickness="2"
                                    Background="#33000000"
                                    SizeChanged="CropRect_SizeChanged"
                                    MouseLeftButtonDown="CropRect_MouseLeftButtonDown"
                                    MouseMove="CropRect_MouseMove"
                                    MouseLeftButtonUp="CropRect_MouseLeftButtonUp">
                                <Grid>
                                    <primitives:Thumb Cursor="SizeAll" DragDelta="CropMoveThumb_DragDelta">
                                        <primitives:Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </primitives:Thumb.Template>
                                    </primitives:Thumb>
                                    <Button x:Name="CropApplyButton"
                                            Content="Cut"
                                            Width="60"
                                            Height="26"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Style="{DynamicResource Sf.ImGuiButton}"
                                            Click="CropApplyButton_Click" />
                                    <primitives:Thumb Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="SizeNWSE" DragDelta="CropTopLeftThumb_DragDelta" />
                                    <primitives:Thumb Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="SizeNESW" DragDelta="CropTopRightThumb_DragDelta" />
                                    <primitives:Thumb Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="SizeNESW" DragDelta="CropBottomLeftThumb_DragDelta" />
                                    <primitives:Thumb Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" DragDelta="CropBottomRightThumb_DragDelta" />
                                </Grid>
                            </Border>
                        </Canvas>
                    </Grid>
                </Border>
            </Grid>
            <primitives:Thumb Grid.RowSpan="2"
                              Width="14"
                              Height="14"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="0,0,2,2"
                              Cursor="SizeNWSE"
                              DragDelta="ResizeThumb_DragDelta">
                <primitives:Thumb.Template>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Border Background="#4D6FAE" CornerRadius="2" />
                    </ControlTemplate>
                </primitives:Thumb.Template>
            </primitives:Thumb>
        </Grid>
    </Border>
</Window>
