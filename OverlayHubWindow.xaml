<Window x:Class="SnapForge.OverlayHubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="SnapForge Overlay"
        Width="490"
        Height="460"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">
    <Border x:Name="RootBorder"
            Background="{DynamicResource Sf.SteamCardBackground}"
            CornerRadius="16"
            BorderBrush="{DynamicResource Sf.SteamCardBorder}"
            BorderThickness="1"
            Padding="10"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <DockPanel>
            <Border DockPanel.Dock="Top"
                    Background="#141B2A"
                    CornerRadius="12"
                    BorderBrush="#2A3C58"
                    BorderThickness="1"
                    Padding="8"
                    Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Recent Screenshots"
                               FontSize="18"
                               Foreground="#EDF3FF"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Folder"
                                Width="74"
                                Height="30"
                                Margin="0,0,6,0"
                                Style="{DynamicResource Sf.ImGuiButton}"
                                Click="OpenFolderButton_Click" />
                        <Button Content="✕"
                                Width="34"
                                Height="30"
                                Style="{DynamicResource Sf.ImGuiButton}"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>
            <ScrollViewer x:Name="GalleryScrollViewer"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly"
                          PreviewMouseWheel="GalleryScrollViewer_PreviewMouseWheel">
                <ItemsControl x:Name="ItemsList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=TileSize}"
                                    Height="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=TileSize}"
                                    Margin="5"
                                    CornerRadius="12"
                                    Background="#101826"
                                    BorderBrush="#2A3C58"
                                    BorderThickness="1"
                                    ClipToBounds="True"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="Tile_MouseLeftButtonDown"
                                    MouseEnter="Tile_MouseEnter"
                                    MouseLeave="Tile_MouseLeave"
                                    Tag="{Binding FilePath}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                    <Border x:Name="HoverOverlay"
                                            Grid.RowSpan="2"
                                            Background="#66000000"
                                            Visibility="Collapsed">
                                        <Button Content="Send"
                                                Width="74"
                                                Height="30"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Tag="{Binding FilePath}"
                                                Style="{DynamicResource Sf.ImGuiButton}"
                                                Click="SendTileButton_Click" />
                                    </Border>
                                    <Border Grid.Row="1"
                                            Background="#D00B1220"
                                            Padding="4,3"
                                            BorderBrush="#2A3C58"
                                            BorderThickness="0,1,0,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Border Grid.Column="0"
                                                        Background="#80111A25"
                                                        CornerRadius="6"
                                                        Padding="2">
                                                    <UniformGrid Columns="3">
                                                        <Button Content="Open"
                                                                Height="20"
                                                                Margin="1"
                                                                FontSize="8"
                                                                Tag="{Binding FilePath}"
                                                                Style="{DynamicResource Sf.ImGuiButton}"
                                                                Click="OpenTileButton_Click" />
                                                        <Button Content="Edit"
                                                                Height="20"
                                                                Margin="1"
                                                                FontSize="8"
                                                                Tag="{Binding FilePath}"
                                                                Style="{DynamicResource Sf.ImGuiButton}"
                                                                Click="EditTileButton_Click" />
                                                        <Button Content="Delete"
                                                                Height="20"
                                                                Margin="1"
                                                                FontSize="8"
                                                                Background="#C93232"
                                                                Foreground="White"
                                                                Tag="{Binding FilePath}"
                                                                Click="DeleteTileButton_Click" />
                                                    </UniformGrid>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            </DockPanel>
            <primitives:Thumb Width="14"
                              Height="14"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="0,0,2,2"
                              Cursor="SizeNWSE"
                              DragDelta="ResizeThumb_DragDelta">
                <primitives:Thumb.Template>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Border Background="#4D6FAE" CornerRadius="2" />
                    </ControlTemplate>
                </primitives:Thumb.Template>
            </primitives:Thumb>
        </Grid>
    </Border>
</Window>
