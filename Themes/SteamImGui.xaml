<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Sf.SteamGlassColor">#CC0B1220</Color>
    <SolidColorBrush x:Key="Sf.SteamCardBackground" Color="{StaticResource Sf.SteamGlassColor}" />
    <SolidColorBrush x:Key="Sf.SteamCardBorder" Color="#334B73" />

    <SolidColorBrush x:Key="Sf.ImGuiAccent" Color="#4C78CC" />
    <SolidColorBrush x:Key="Sf.ImGuiAccentHover" Color="#5A89E0" />
    <SolidColorBrush x:Key="Sf.ImGuiAccentPressed" Color="#3F66AF" />
    <SolidColorBrush x:Key="Sf.ImGuiPanelBg" Color="#0F1623" />
    <SolidColorBrush x:Key="Sf.ImGuiPanelBgAlt" Color="#121C2B" />
    <SolidColorBrush x:Key="Sf.ImGuiPanelBorder" Color="#2A3C58" />

    <Style x:Key="Sf.ImGuiButton" TargetType="Button">
        <Setter Property="Foreground" Value="#EAF0FF" />
        <Setter Property="Background" Value="{StaticResource Sf.ImGuiAccent}" />
        <Setter Property="BorderBrush" Value="#2E4570" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="9,4" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Sf.ImGuiAccentHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Sf.ImGuiAccentPressed}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Sf.ImGuiTextBox" TargetType="TextBox">
        <Setter Property="Foreground" Value="#EAF0FF" />
        <Setter Property="Background" Value="{StaticResource Sf.ImGuiPanelBg}" />
        <Setter Property="BorderBrush" Value="{StaticResource Sf.ImGuiPanelBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="7,4" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="CaretBrush" Value="#DCE8FF" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#5B8CFF" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Sf.ImGuiCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="#DDE7FF" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="Box"
                                Width="14"
                                Height="14"
                                CornerRadius="3"
                                BorderThickness="1"
                                BorderBrush="{StaticResource Sf.ImGuiPanelBorder}"
                                Background="{StaticResource Sf.ImGuiPanelBg}"
                                VerticalAlignment="Center">
                            <Path x:Name="Tick"
                                  Visibility="Collapsed"
                                  Stroke="#9DC0FF"
                                  StrokeThickness="2"
                                  Data="M 2 8 L 6 12 L 13 3" />
                        </Border>
                        <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="#1F3150" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="#5B8CFF" />
                            <Setter TargetName="Tick" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Box" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Sf.ImGuiSlider" TargetType="Slider">
        <Setter Property="Foreground" Value="#5B8CFF" />
        <Setter Property="Background" Value="{StaticResource Sf.ImGuiPanelBg}" />
        <Setter Property="MinHeight" Value="18" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid Margin="0,3">
                        <Border Height="4" CornerRadius="2" Background="#172234" VerticalAlignment="Center" />
                        <Track x:Name="PART_Track" VerticalAlignment="Center">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Background="#5B8CFF" BorderThickness="0" Height="4" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Width="10" Height="10">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#8FB2FF" BorderBrush="#2A3C58" BorderThickness="1" CornerRadius="5" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Background="#172234" BorderThickness="0" Height="4" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Sf.ImGuiTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource Sf.ImGuiPanelBg}" />
        <Setter Property="BorderBrush" Value="{StaticResource Sf.ImGuiPanelBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="Sf.ImGuiTabItem" TargetType="TabItem">
        <Setter Property="Foreground" Value="#BFD3F6" />
        <Setter Property="Background" Value="{StaticResource Sf.ImGuiPanelBgAlt}" />
        <Setter Property="BorderBrush" Value="{StaticResource Sf.ImGuiPanelBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="9,2" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Margin="0,0,4,0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1B2B45" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#5B8CFF" />
                            <Setter Property="Foreground" Value="#EAF0FF" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#172538" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Sf.ImGuiScrollViewer" TargetType="ScrollViewer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="8" />
                        </Grid.RowDefinitions>
                        <ScrollContentPresenter Grid.Row="0" Grid.Column="0" />
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   Orientation="Vertical"
                                   Width="8"
                                   Background="#00101622"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Value="{Binding VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}" />
                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Grid.Row="1"
                                   Grid.Column="0"
                                   Orientation="Horizontal"
                                   Height="8"
                                   Background="#00101622"
                                   Maximum="{TemplateBinding ScrollableWidth}"
                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                   Value="{Binding HorizontalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
