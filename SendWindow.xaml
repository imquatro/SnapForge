<Window x:Class="SnapForge.SendWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Send Screenshot"
        Width="760"
        Height="520"
        Background="#0F1520"
        Foreground="#EAF0FF">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Select an open window"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10" />
        <ListBox x:Name="WindowsListBox" Grid.Row="1" DisplayMemberPath="Title" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Refresh" Width="100" Margin="0,0,10,0" Click="RefreshButton_Click" />
            <Button Content="Send" Width="110" Click="SendButton_Click" />
            <TextBlock x:Name="StatusText" Margin="14,0,0,0" VerticalAlignment="Center" Foreground="#9EC0F7" />
        </StackPanel>
    </Grid>
</Window>
