<Window x:Class="SnapForge.SendWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Title="Send Screenshot"
        Width="820"
        Height="620"
        Foreground="#EAF0FF">
    <Border Background="{DynamicResource Sf.SteamCardBackground}"
            BorderBrush="{DynamicResource Sf.SteamCardBorder}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Send to open application"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="FileNameText"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="#7FA8D8"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Button Grid.Column="1"
                        Width="32"
                        Height="28"
                        Content="✕"
                        Style="{DynamicResource Sf.ImGuiButton}"
                        Click="CloseButton_Click" />
            </Grid>

            <TextBlock Grid.Row="1"
                       Text="Pick a window, then press Send."
                       FontSize="12"
                       Foreground="#9DB2D4"
                       Margin="0,0,0,10" />

            <ListBox x:Name="WindowsListBox"
                     Grid.Row="2"
                     Style="{DynamicResource Sf.ImGuiListBox}"
                     ItemContainerStyle="{DynamicResource Sf.ImGuiListBoxItem}"
                     SelectionMode="Single"
                     MouseDoubleClick="WindowsListBox_MouseDoubleClick">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal">
                            <WrapPanel.Width>
                                <Binding RelativeSource="{RelativeSource AncestorType=ScrollViewer}" Path="ViewportWidth" />
                            </WrapPanel.Width>
                        </WrapPanel>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="182"
                                Height="156"
                                Margin="0,0,10,10"
                                Background="#141E2E"
                                BorderBrush="#2A3C58"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="10,12,10,10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                            <Setter Property="BorderBrush" Value="#FFD254" />
                                            <Setter Property="BorderThickness" Value="2" />
                                            <Setter Property="Background" Value="#1A2940" />
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#5B8CFF" />
                                            <Setter Property="Background" Value="#182536" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border HorizontalAlignment="Center"
                                        Width="64"
                                        Height="64"
                                        Background="#0E1522"
                                        BorderBrush="#334B73"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Margin="0,0,0,10">
                                    <Image Source="{Binding IconSource}"
                                           Width="48"
                                           Height="48"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Border>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding ProcessName}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#EAF0FF"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="158" />
                                <TextBlock Grid.Row="2"
                                           Margin="0,6,0,0"
                                           Text="{Binding Title}"
                                           FontSize="11"
                                           LineHeight="15"
                                           Foreground="#8FAFD8"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="34"
                                           MaxWidth="158" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Content="Refresh"
                        Width="100"
                        Height="28"
                        Margin="0,0,10,0"
                        Style="{DynamicResource Sf.ImGuiButton}"
                        Click="RefreshButton_Click" />
                <Button Grid.Column="1"
                        Content="Send"
                        Width="110"
                        Height="28"
                        Style="{DynamicResource Sf.ImGuiButton}"
                        Click="SendButton_Click" />
                <TextBlock x:Name="StatusText"
                           Grid.Column="2"
                           Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#88D8A3"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Grid>
    </Border>
</Window>
